# ─── 데이터베이스 ────────────────────────────────────────────────────
# PostgreSQL 연결 문자열 (Replit에서는 DATABASE_URL이 자동 설정됨)
DATABASE_URL=postgresql://user:password@localhost:5432/gupsike

# ─── 세션 ────────────────────────────────────────────────────────────
# 세션 쿠키 서명 키 (충분히 긴 랜덤 문자열 사용)
SESSION_SECRET=change-me-to-a-long-random-secret

# ─── DashScope (Alibaba Model Studio) ───────────────────────────────
# https://dashscope.aliyun.com 에서 발급 (국내망)
# 국제망 엔드포인트 사용 시: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ─── NEIS 교육정보 개방포털 API ──────────────────────────────────────
# https://open.neis.go.kr 에서 발급
# 미설정 시 Mock 데이터로 자동 대체됨
NEIS_API_KEY=

# ─── S3 호환 이미지 스토리지 ─────────────────────────────────────────
# 프로덕션: AWS S3, Cloudflare R2 등 S3 호환 스토리지
# 로컬 개발: MinIO (docker-compose로 실행) 또는 미설정(로컬 /uploads/ fallback)
#
# docker-compose로 MinIO 로컬 실행 예시:
#   services:
#     minio:
#       image: minio/minio
#       ports: ["9000:9000", "9001:9001"]
#       environment:
#         MINIO_ROOT_USER: minioadmin
#         MINIO_ROOT_PASSWORD: minioadmin
#       command: server /data --console-address ":9001"
#
# S3 미설정 시 → uploads/ 디렉토리에 로컬 저장, /uploads/ 경로로 서빙
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=gupsik-e
# 클라이언트가 이미지를 직접 불러올 공개 URL (버킷 퍼블릭 정책 필요)
S3_PUBLIC_URL=http://localhost:9000/gupsik-e
